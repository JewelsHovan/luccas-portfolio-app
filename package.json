{
  "name": "luccas-portfolio-app",
  "private": true,
  "version": "1.0.0",
  "description": "Luccas Portfolio with dynamic image overlays",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:frontend": "pnpm --filter frontend run dev",
    "dev:backend": "pnpm --filter ./backend run dev",
    "build": "pnpm --filter frontend run build",
    "start": "pnpm --filter ./backend run start",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "vitest": "^4.1.2"
  }
}